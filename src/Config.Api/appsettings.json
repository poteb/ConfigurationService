{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": { "path":  "D:/Logs/configapi.txt", "fileSizeLimitBytes": 10485760, "retainedFileCountLimit": 10,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  },
  "DataProvider": "SqlServer",
  "FileDatabase": {
    "Directory": "D:\\ConfigurationDatabase"
  },
  "SqlServer": {
    "ConnectionString": "Data Source=.;Database=ConfigurationService;Integrated Security=true;Encrypt=False"
  },
  "EncryptionSettings": {
    "JsonEncryptionKey": "YouShouldChangeThisKey(32_Bytes)"
  }
}
